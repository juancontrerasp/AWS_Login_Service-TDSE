# ── .env.example ──────────────────────────────────────────────────────────────
# Template for environment configuration
# Copy .env.production to .env for the pre-configured deployment
# OR copy this file to .env and customize for your own deployment
# ──────────────────────────────────────────────────────────────────────────────

# Database Configuration
DB_NAME=logindb
DB_USER=loginuser
DB_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# JWT Configuration
# JWT secret must be at least 256 bits (32+ characters)
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_STRING_USE_OPENSSL_RAND
JWT_EXPIRATION_MS=86400000

# CORS Configuration
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://your-frontend-domain.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
